class Solution {
public:
    int longestConsecutive(vector<int>& nums) {
        unordered_set<int> st(nums.begin(), nums.end());
        int n = nums.size();
        int maxLen = 0;

        for(int i = 0; i < n; i++){
            if(!st.count(nums[i] - 1)){
                int length = 1;
                while(st.count(nums[i] + length)){
                    length++;
                }
                maxLen = max(maxLen, length);
            }
        }
        return maxLen;
    }
};
